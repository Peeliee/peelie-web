{
  "name": "@peelie/bridge",
  "version": "0.0.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./testing": {
      "types": "./src/testing.ts",
      "import": "./src/testing.ts"
    },
    "./react": {
      "types": "./src/react.ts",
      "import": "./src/react.ts"
    },
    "./react-native": {
      "types": "./src/react-native.ts",
      "import": "./src/react-native.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "vitest": "^3.2.4"
  }
}
