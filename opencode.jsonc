{
    "$schema": "https://opencode.ai/config.json",
    "instructions": ["instructions.md"],
    "mcp": {
        "figma": {
            "url": "https://mcp.figma.com/mcp",
            "type": "remote",
            "enabled": true,
        },
    },
    "context7": {
        "type": "remote",
        "url": "https://mcp.context7.com/mcp",
        "headers": {
            "CONTEXT7_API_KEY": "YOUR_API_KEY",
        },
        "enabled": true,
    },
    "autoupdate": true,
    "server": {
        "port": 4096,
    },
}
